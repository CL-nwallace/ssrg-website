NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — grants bypass of RLS. Only used by e2e tests. NEVER add to Vercel.
SUPABASE_SERVICE_ROLE_KEY=
# Gates the test-only /api/test/admin-session endpoint used by Playwright's non-admin
# middleware test. NEVER add to Vercel — if unset, the endpoint 404s.
TEST_AUTH_SECRET=
